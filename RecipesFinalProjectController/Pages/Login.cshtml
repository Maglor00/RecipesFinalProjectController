@page
@model RecipesFinalProjectController.Pages.LoginModel
@{
    ViewData["Title"] = "Login";
}

@section Styles {
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
}

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-header">
            <h1 class="auth-title">Welcome back</h1>
            <p class="auth-subtitle">Log in to continue saving favorites and sharing recipes.</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="alert alert-danger mb-3">
                @Model.ErrorMessage
            </div>
        }

        <form method="post" class="auth-form">
            <div class="mb-3">
                <label class="form-label auth-label">Username</label>
                <input asp-for="UserName" class="form-control auth-input" />
            </div>

            <div class="mb-4">
                <label class="form-label auth-label">Password</label>
                <input asp-for="Password" type="password" class="form-control auth-input" />
            </div>

            <button type="submit" class="btn btn-main auth-submit">Login</button>
        </form>

        <div class="auth-footer">
            <span>Don’t have an account?</span>
            <a asp-page="/Register">Register</a>
        </div>
    </div>
</div>
