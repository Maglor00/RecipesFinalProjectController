@page
@model RecipesFinalProjectController.Pages.Admin.RecipeApprovalModel
@{
    ViewData["Title"] = "Admin Panel";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-panel.css" asp-append-version="true" />
}

<div class="admin-page">
    <div class="admin-shell">
        <div class="admin-header">
            <h1 class="page-title">Admin Panel</h1>
            <p class="admin-subtitle">
                Review and approve recipes, categories, and difficulties submitted by users.
            </p>
        </div>

        @if (TempData["Message"] != null)
        {
            <div class="alert alert-success">
                @TempData["Message"]
            </div>
        }

        <section class="admin-section">
            <div class="admin-section-header">
                <h2 class="admin-section-title">Pending Recipes</h2>
                <span class="admin-count">@Model.PendingRecipes.Count</span>
            </div>

            @if (!Model.PendingRecipes.Any())
            {
                <div class="empty-state">
                    There are no pending recipes waiting for approval.
                </div>
            }
            else
            {
                <div class="admin-recipes-grid">
                    @foreach (var recipe in Model.PendingRecipes)
                    {
                        <div class="admin-recipe-card">
                            @if (!string.IsNullOrWhiteSpace(recipe.ImageUrl))
                            {
                                <img src="@recipe.ImageUrl"
                                     class="admin-recipe-image"
                                     alt="@recipe.Title" />
                            }
                            else
                            {
                                <div class="admin-recipe-image admin-recipe-placeholder">
                                    <span>No image</span>
                                </div>
                            }

                        <div class="admin-recipe-body">
                            <h3 class="admin-recipe-title">@recipe.Title</h3>

                            <div class="admin-recipe-meta">
                                <span class="detail-chip">@recipe.Category?.Name</span>
                                <span class="detail-chip">@recipe.Difficulty?.Name</span>
                                <span class="detail-chip">@recipe.PreparationTime min</span>
                            </div>

                            <p class="admin-recipe-author">
                                <strong>Author:</strong> @recipe.User?.Username
                            </p>

                            <p class="admin-recipe-text">
                                @(string.IsNullOrWhiteSpace(recipe.PreparationMethod)
                                                            ? "No preparation method."
                                                            : (recipe.PreparationMethod.Length > 140
                                                            ? recipe.PreparationMethod.Substring(0, 140) + "..."
                                                            : recipe.PreparationMethod))
                        </p>

                                <div class="admin-actions">
                                    <form method="post" asp-page-handler="Approve" class="admin-action-form">
                                        <input type="hidden" name="recipeId" value="@recipe.Id" />
                                        <button type="submit" class="btn btn-success admin-btn">Approve</button>
                                    </form>

                                    <form method="post" asp-page-handler="Delete" class="admin-action-form">
                                        <input type="hidden" name="recipeId" value="@recipe.Id" />
                                        <button type="submit" class="btn btn-outline-danger admin-btn">Delete</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                                }
                </div>
            }
        </section>

        <section class="admin-section">
            <div class="admin-section-header">
                <h2 class="admin-section-title">Pending Categories</h2>
                <span class="admin-count">@Model.PendingCategories.Count</span>
            </div>

            @if (!Model.PendingCategories.Any())
            {
                <div class="empty-state">
                    There are no pending categories.
                </div>
            }
            else
            {
                <div class="admin-list-card">
                    @foreach (var category in Model.PendingCategories)
                    {
                        <div class="admin-list-row">
                            <span class="admin-list-name">@category.Name</span>

                            <form method="post" asp-page-handler="ApproveCategory" class="m-0">
                                <input type="hidden" name="categoryId" value="@category.Id" />
                                <button type="submit" class="btn btn-success admin-small-btn">Approve</button>
                            </form>
                        </div>
                    }
                </div>
            }
        </section>

        <section class="admin-section">
            <div class="admin-section-header">
                <h2 class="admin-section-title">Pending Difficulties</h2>
                <span class="admin-count">@Model.PendingDifficulties.Count</span>
            </div>

            @if (!Model.PendingDifficulties.Any())
            {
                <div class="empty-state">
                    There are no pending difficulties.
                </div>
            }
            else
            {
                <div class="admin-list-card">
                    @foreach (var difficulty in Model.PendingDifficulties)
                    {
                        <div class="admin-list-row">
                            <span class="admin-list-name">@difficulty.Name</span>

                            <form method="post" asp-page-handler="ApproveDifficulty" class="m-0">
                                <input type="hidden" name="difficultyId" value="@difficulty.Id" />
                                <button type="submit" class="btn btn-success admin-small-btn">Approve</button>
                            </form>
                        </div>
                    }
                </div>
            }
        </section>
    </div>
</div>


