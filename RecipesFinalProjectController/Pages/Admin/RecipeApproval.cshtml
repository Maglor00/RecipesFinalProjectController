@page
@model RecipesFinalProjectController.Pages.Admin.RecipeApprovalModel
@{
    ViewData["Title"] = "Recipe Approval";
}

<h2 class="mb-4">@ViewData["Title"]</h2>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success">
        @TempData["Message"]
    </div>
}

<h3 class="mb-3">Pending Recipes</h3>

@if (!Model.PendingRecipes.Any())
{
    <div class="alert alert-info">
        There are no pending recipes waiting for approval.
    </div>
}
else
{
    <div class="row">
        @foreach (var recipe in Model.PendingRecipes)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    @if (!string.IsNullOrWhiteSpace(recipe.ImageUrl))
                    {
                        <img src="@recipe.ImageUrl"
                             class="card-img-top"
                             alt="@recipe.Title"
                             style="height:220px; object-fit:cover;" />
                    }
                    else
                    {
                        <div class="d-flex align-items-center justify-content-center bg-light"
                             style="height:220px;">
                            <span class="text-muted">No image</span>
                        </div>
                    }

                <div class="card-body">
                    <h5 class="card-title">@recipe.Title</h5>

                    <p class="mb-2">
                        <span class="badge bg-secondary">@recipe.Category?.Name</span>
                        <span class="badge bg-dark">@recipe.Difficulty?.Name</span>
                    </p>

                    <p class="text-muted mb-2">
                        <strong>Time:</strong> @recipe.PreparationTime min
                    </p>

                    <p class="text-muted mb-2">
                        <strong>Author:</strong> @recipe.User?.Username
                    </p>

                    <p class="card-text">
                        @(string.IsNullOrWhiteSpace(recipe.PreparationMethod)
                                            ? "No preparation method."
                                            : (recipe.PreparationMethod.Length > 140
                                            ? recipe.PreparationMethod.Substring(0, 140) + "..."
                                            : recipe.PreparationMethod))
                </p>
            </div>

                    <div class="card-footer bg-white border-0 d-flex gap-2">
                        <form method="post" asp-page-handler="Approve" class="w-50">
                            <input type="hidden" name="recipeId" value="@recipe.Id" />
                            <button type="submit" class="btn btn-success w-100">Approve</button>
                        </form>

                        <form method="post" asp-page-handler="Delete" class="w-50">
                            <input type="hidden" name="recipeId" value="@recipe.Id" />
                            <button type="submit" class="btn btn-outline-danger w-100">Delete</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}

<hr class="my-5" />

<h3 class="mb-3">Pending Categories</h3>

@if (!Model.PendingCategories.Any())
{
    <div class="alert alert-info">
        There are no pending categories.
    </div>
}
else
{
    <div class="list-group mb-5">
        @foreach (var category in Model.PendingCategories)
        {
            <div class="list-group-item d-flex justify-content-between align-items-center">
                <span>@category.Name</span>
                <form method="post" asp-page-handler="ApproveCategory" class="m-0">
                    <input type="hidden" name="categoryId" value="@category.Id" />
                    <button type="submit" class="btn btn-success btn-sm">Approve</button>
                </form>
            </div>
        }
    </div>
}

<h3 class="mb-3">Pending Difficulties</h3>

@if (!Model.PendingDifficulties.Any())
{
    <div class="alert alert-info">
        There are no pending difficulties.
    </div>
}
else
{
    <div class="list-group">
        @foreach (var difficulty in Model.PendingDifficulties)
        {
            <div class="list-group-item d-flex justify-content-between align-items-center">
                <span>@difficulty.Name</span>
                <form method="post" asp-page-handler="ApproveDifficulty" class="m-0">
                    <input type="hidden" name="difficultyId" value="@difficulty.Id" />
                    <button type="submit" class="btn btn-success btn-sm">Approve</button>
                </form>
            </div>
        }
    </div>
}


