@page
@model RecipesFinalProjectController.Pages.CreateRecipeModel
@{
    ViewData["Title"] = "Create Recipe";
}

@section Styles {
    <link rel="stylesheet" href="~/css/create-recipe.css" asp-append-version="true" />
}

<div class="create-recipe-page">
    <h2 class="page-title">Create Recipe</h2>

    @if (!string.IsNullOrWhiteSpace(Model.Message))
    {
        <div class="alert alert-success" data-auto-hide="true">
            @Model.Message
        </div>
    }

    @if (!ViewContext.ModelState.IsValid)
    {
        <div asp-validation-summary="All" class="alert alert-danger"></div>
    }

    <form method="post" enctype="multipart/form-data" class="form-panel p-4">
        <div class="mb-3">
            <label class="form-label">Title</label>
            <input asp-for="Recipe.Title" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Preparation Method</label>
            <textarea asp-for="Recipe.PreparationMethod" class="form-control" rows="5"></textarea>
        </div>

        <div class="mb-3">
            <label class="form-label">Preparation Time (minutes)</label>
            <input asp-for="Recipe.PreparationTime" type="number" step="1" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Recipe Image</label>
            <input asp-for="ImageFile" type="file" accept="image/*" class="form-control" id="imageInput" />
        </div>

        <div class="mb-3" id="imagePreviewContainer" style="display:none;">
            <img id="imagePreview" alt="Preview" />
        </div>

        <div class="mb-3">
            <label class="form-label">Category</label>
            <select asp-for="CategoryId" class="form-select">
                <option value="">Select category</option>
                @foreach (var c in Model.Categories)
                {
                    <option value="@c.Id">@c.Name</option>
                }
            </select>
            <div class="form-text">
                Or type a new category below. New categories are pending admin approval.
            </div>
            <input asp-for="NewCategoryName" class="form-control mt-2" placeholder="New category name" />
        </div>

        <div class="mb-3">
            <label class="form-label">Difficulty</label>
            <select asp-for="DifficultyId" class="form-select">
                <option value="">Select difficulty</option>
                @foreach (var d in Model.Difficulties)
                {
                    <option value="@d.Id">@d.Name</option>
                }
            </select>
            <div class="form-text">
                Or type a new difficulty below. New difficulties are pending admin approval.
            </div>
            <input asp-for="NewDifficultyName" class="form-control mt-2" placeholder="New difficulty name" />
        </div>

        <h4 class="section-title mt-4">Ingredients</h4>

        <table class="table ingredients-table" id="ingredientsTable">
            <thead>
                <tr>
                    <th>Ingredient</th>
                    <th>New Ingredient</th>
                    <th>Quantity</th>
                    <th>Measure</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>
                        <select name="IngredientIds" class="form-select">
                            <option value="">Select ingredient</option>
                            @foreach (var i in Model.Ingredients)
                            {
                                <option value="@i.Id">@i.Name</option>
                            }
                        </select>
                    </td>
                    <td>
                        <input name="NewIngredientNames"
                               class="form-control"
                               placeholder="Or type new ingredient" />
                    </td>
                    <td>
                        <input name="Quantities" type="number" step="0.01" min="0.01" class="form-control" />
                    </td>
                    <td>
                        <input name="Measures" class="form-control" placeholder="g / ml / pcs" />
                    </td>
                    <td>
                        <button type="button" class="btn btn-outline-danger" onclick="removeRow(this)">X</button>
                    </td>
                </tr>
            </tbody>
        </table>

        <div class="form-text mb-3">
            If you type a new ingredient, the ingredient dropdown in that row will be disabled.
            If you select an ingredient from the dropdown, the new ingredient input will be disabled.
        </div>

        <button type="button" class="btn btn-outline-secondary mb-3" onclick="addIngredientRow()">
            Add Ingredient
        </button>

        <div>
            <button type="submit" class="btn btn-main">Create Recipe</button>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/js/create-recipe.js" asp-append-version="true"></script>
}