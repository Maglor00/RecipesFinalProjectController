@page
@model RecipesFinalProjectController.Pages.FavoritesModel
@{
    ViewData["Title"] = "Favorites";
}

<h2>@ViewData["Title"]</h2>

@foreach (var recipe in Model.Favorites)
{
    <div class="card mb-3 p-3">
        <h4>@recipe.Title</h4>
        <p>@recipe.Category.Name</p>
        <p>@recipe.Difficulty.Name</p>
    </div>
}
