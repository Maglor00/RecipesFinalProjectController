@page
@model RecipesFinalProjectController.Pages.ProfileModel
@{
    ViewData["Title"] = "Profile";
}

@section Styles {
    <link rel="stylesheet" href="~/css/profile.css" asp-append-version="true" />
}

<div class="profile-page">
    <h2 class="page-title">My Profile</h2>

    @if (!string.IsNullOrWhiteSpace(Model.Message))
    {
        <div class="alert alert-success" data-auto-hide="true">
            @Model.Message
        </div>
    }

    @if (!ViewContext.ModelState.IsValid)
    {
        <div asp-validation-summary="All" class="alert alert-danger"></div>
    }

    <div class="row">
        <div class="col-md-6">
            <div class="form-panel p-4 mb-4">
                <h4 class="section-title">Personal Information</h4>

                <div class="mb-4 text-center">
                    @if (!string.IsNullOrWhiteSpace(Model.CurrentUser.AvatarUrl))
                    {
                        <img src="@Model.CurrentUser.AvatarUrl" class="profile-avatar-large" alt="@Model.Username" />
                    }
                    else
                    {
                        <div class="profile-avatar-large profile-avatar-placeholder">
                            @(string.IsNullOrWhiteSpace(Model.Username) ? "U" : Model.Username.Substring(0, 1).ToUpper())
                        </div>
                    }
                </div>

                <form method="post" asp-page-handler="UpdateProfile" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label class="form-label profile-label">First Name</label>
                        <input asp-for="FirstName" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label profile-label">Last Name</label>
                        <input asp-for="LastName" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label profile-label">Username</label>
                        <input asp-for="Username" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label profile-label">Avatar</label>
                        <input asp-for="AvatarFile" type="file" accept="image/*" class="form-control" />
                    </div>

                    <button type="submit" class="btn btn-main">Save Profile</button>
                </form>
            </div>
        </div>

        <div class="col-md-6">
            <div class="form-panel p-4 security-box">
                <h4 class="section-title">Security</h4>

                <button type="button" class="btn btn-outline-secondary" id="togglePasswordFormBtn">
                    Change Password
                </button>

                <div id="changePasswordContainer" class="mt-3">
                    <form method="post" asp-page-handler="ChangePassword">
                        <div class="mb-3">
                            <label class="form-label profile-label">Current Password</label>
                            <input asp-for="CurrentPassword" type="password" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label profile-label">New Password</label>
                            <input asp-for="NewPassword" type="password" class="form-control" />
                        </div>

                        <button type="submit" class="btn btn-main">Save New Password</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/profile.js" asp-append-version="true"></script>
}