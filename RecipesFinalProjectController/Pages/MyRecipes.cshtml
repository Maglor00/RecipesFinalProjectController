@page
@model RecipesFinalProjectController.Pages.MyRecipesModel
@{
    ViewData["Title"] = "My Recipes";
}

@section Styles {
    <link rel="stylesheet" href="~/css/my-recipes.css" asp-append-version="true" />
}

<div class="my-recipes-page">
    <div class="my-recipes-shell">
        <div class="my-recipes-header">
            <h1 class="page-title">My Recipes</h1>
            <p class="my-recipes-subtitle">
                Manage the recipes you created, check their approval status, and edit them when needed.
            </p>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.Message))
        {
            <div class="alert alert-success" data-auto-hide="true">
                @Model.Message
            </div>
        }

        @if (Model.Recipes.Any())
        {
            <div class="my-recipes-grid">
                @foreach (var recipe in Model.Recipes)
                {
                    <div class="manage-recipe-card">
                        <a asp-page="/RecipeDetails" asp-route-id="@recipe.Id" class="manage-recipe-image-link">
                            @if (!string.IsNullOrWhiteSpace(recipe.ImageUrl))
                            {
                                <img src="@recipe.ImageUrl" class="manage-recipe-image" alt="@recipe.Title" />
                            }
                            else
                            {
                                <div class="manage-recipe-image manage-recipe-placeholder">
                                    <span>No image</span>
                                </div>
                            }
                        </a>

                        <div class="manage-recipe-body">
                            <div class="manage-recipe-top">
                                <a asp-page="/RecipeDetails" asp-route-id="@recipe.Id" class="manage-recipe-title-link">
                                    <h3 class="manage-recipe-title">@recipe.Title</h3>
                                </a>

                                @if (recipe.IsApproved)
                                {
                                    <span class="status-chip approved">Approved</span>
                                }
                                else
                                {
                                    <span class="status-chip pending">Pending</span>
                                }
                            </div>

                            <div class="manage-recipe-meta">
                                @if (recipe.Category != null && !string.IsNullOrWhiteSpace(recipe.Category.Name))
                                {
                                    <span>@recipe.Category.Name</span>
                                }

                                <span class="meta-dot">•</span>

                                @if (recipe.Difficulty != null && !string.IsNullOrWhiteSpace(recipe.Difficulty.Name))
                                {
                                    <span>@recipe.Difficulty.Name</span>
                                }

                                <span class="meta-dot">•</span>
                                <span>@recipe.PreparationTime min</span>
                            </div>

                            <div class="manage-recipe-actions">
                                <a asp-page="/EditRecipe" asp-route-id="@recipe.Id" class="btn btn-main manage-btn">
                                    Edit Recipe
                                </a>

                                <form method="post" asp-page-handler="Delete" class="manage-delete-form">
                                    <input type="hidden" name="recipeId" value="@recipe.Id" />
                                    <button type="submit" class="btn btn-outline-danger manage-btn">
                                        Delete
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                You have not created any recipes yet.
            </div>
        }
    </div>
</div>
