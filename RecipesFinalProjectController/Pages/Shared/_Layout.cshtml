@using System.Security.Claims
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RecipeHub</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RecipesFinalProjectController.styles.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @{
        bool isLoggedIn = User.Identity != null && User.Identity.IsAuthenticated;
        bool isAdmin = User.FindFirst("is_admin")?.Value == "True";
        string username = User.Identity?.Name ?? "";
    }

    <header>
        <nav class="navbar navbar-expand-lg navbar-light recipe-navbar mb-4">
            <div class="container">
                <a class="navbar-brand recipe-brand" asp-page="/Index">RecipeHub</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-page="/Index">Home</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-page="/Search">Search</a>
                        </li>

                        @if (isLoggedIn)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/CreateRecipe">Create Recipe</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/MyFavorites">My Favorites</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/Profile">Profile</a>
                            </li>

                            @if (isAdmin)
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-danger fw-bold" asp-page="/Admin/RecipeApproval">
                                        Admin Panel
                                    </a>
                                </li>
                            }
                        }
                    </ul>

                    <form class="d-flex me-3" method="get" asp-page="/Search">
                        <input class="form-control"
                               type="search"
                               name="title"
                               placeholder="Search recipes..."
                               value="@Context.Request.Query["title"]" />
                        <button class="btn btn-main ms-2" type="submit">Search</button>
                    </form>

                    <ul class="navbar-nav">
                        @if (isLoggedIn)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-dark">Hello, @username</span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/Logout">Logout</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/Register">Register</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-muted mt-4">
        <div class="container py-3">
            &copy; 2026 - RecipeHub
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>