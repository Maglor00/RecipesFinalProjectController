@model RecipesFinalProjectModels.Recipes

<div class="recipe-card">
    <a asp-page="/RecipeDetails" asp-route-id="@Model.Id" class="recipe-card-image-link">
        @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" class="recipe-card-image" alt="@Model.Title" />
        }
        else
        {
            <div class="recipe-card-image recipe-card-placeholder">
                <span>No image</span>
            </div>
        }
    </a>

    <div class="recipe-card-body">
        <div class="recipe-card-header">
            <a asp-page="/RecipeDetails" asp-route-id="@Model.Id" class="recipe-card-title-link">
                <h3 class="recipe-card-title">@Model.Title</h3>
            </a>

            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <form method="post" asp-page="/Search" asp-page-handler="ToggleFavorite" class="favorite-form">
                    <input type="hidden" name="recipeId" value="@Model.Id" />

                    <button type="submit" class="favorite-btn" title="Toggle favorite">
                        @if (Model.IsFavorite)
                        {
                            <span class="favorite-icon active">❤</span>
                        }
                        else
                        {
                            <span class="favorite-icon">♡</span>
                        }
                    </button>
                </form>
            }
        </div>

        <div class="recipe-meta">
            @if (Model.Category != null && !string.IsNullOrWhiteSpace(Model.Category.Name))
            {
                <span>@Model.Category.Name</span>
            }
        </div>

        <div class="recipe-meta">
            @if (Model.Difficulty != null && !string.IsNullOrWhiteSpace(Model.Difficulty.Name))
            {
                <span>@Model.Difficulty.Name</span>
            }

            <span class="meta-dot">•</span>
            <span>@Model.PreparationTime min</span>
        </div>
    </div>
</div>

