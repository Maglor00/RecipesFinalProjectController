@page
@model RecipesFinalProjectController.Pages.SearchModel
@{
    ViewData["Title"] = "Search";
}

@section Styles {
    <link rel="stylesheet" href="~/css/search.css" asp-append-version="true" />
}

<h2>@ViewData["Title"]</h2>

<div class="search-page">
    <h2 class="page-title">Find Recipes</h2>

    <form method="get" class="search-panel mb-4 p-3">
        <div class="row filter-row">
            <div class="col-md-3">
                <input asp-for="Title" class="form-control" placeholder="Recipe title" />
            </div>

            <div class="col-md-3">
                <select asp-for="CategoryId" class="form-select">
                    <option value="">All Categories</option>
                    @foreach (var category in Model.Categories)
                    {
                        <option value="@category.Id">@category.Name</option>
                    }
                </select>
            </div>

            <div class="col-md-3">
                <select asp-for="DifficultyId" class="form-select">
                    <option value="">All Difficulties</option>
                    @foreach (var difficulty in Model.Difficulties)
                    {
                        <option value="@difficulty.Id">@difficulty.Name</option>
                    }
                </select>
            </div>

            <div class="col-md-2">
                <input asp-for="MaxTime" type="number" class="form-control" placeholder="Max time" />
            </div>

            <div class="col-md-1">
                <button class="btn btn-main w-100">Go</button>
            </div>
        </div>
    </form>

    @if (Model.Recipes.Any())
    {
        <div class="row recipe-grid">
            @foreach (var recipe in Model.Recipes)
            {
                <div class="col-md-4 mb-4">
                    <partial name="_RecipeCard" model="recipe" />
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            No recipes found.
        </div>
    }
</div>

@section Scripts {
    <script src="~/js/search.js" asp-append-version="true"></script>
}
