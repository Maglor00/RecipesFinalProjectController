@page
@model RecipesFinalProjectController.Pages.SearchModel
@{
    ViewData["Title"] = "Search";
}

@section Styles {
    <link rel="stylesheet" href="~/css/search.css" asp-append-version="true" />
}

<div class="search-page">
    <div class="search-shell">
        <div class="search-header">
            <h1 class="page-title">Find Recipes</h1>
            <p class="search-subtitle">Search by title, filter by category or difficulty, and find your next meal.</p>
        </div>

        <form method="get" class="search-panel">
            <div class="search-main-row">
                <div class="search-input-wrap">
                    <span class="search-icon">⌕</span>
                    <input asp-for="Title"
                           class="search-input"
                           placeholder="Search recipes..."
                           onkeydown="if(event.key === 'Enter'){ this.form.submit(); }" />
                </div>
            </div>

            <div class="filter-row">
                <div class="filter-pill">
                    <select asp-for="CategoryId" class="filter-select" onchange="this.form.submit()">
                        <option value="">All Categories</option>
                        @foreach (var category in Model.Categories)
                        {
                            <option value="@category.Id">@category.Name</option>
                        }
                    </select>
                </div>

                <div class="filter-pill">
                    <select asp-for="DifficultyId" class="filter-select" onchange="this.form.submit()">
                        <option value="">All Difficulties</option>
                        @foreach (var difficulty in Model.Difficulties)
                        {
                            <option value="@difficulty.Id">@difficulty.Name</option>
                        }
                    </select>
                </div>

                <div class="filter-pill time-pill">
                    <input asp-for="MaxTime"
                           type="number"
                           class="filter-time"
                           placeholder="Max time"
                           onkeydown="if(event.key === 'Enter'){ this.form.submit(); }" />
                </div>

                <div class="results-count">
                    @Model.Recipes.Count results
                </div>
            </div>
        </form>

        @if (Model.Recipes.Any())
        {
            <div class="recipe-grid">
                @foreach (var recipe in Model.Recipes)
                {
                    <partial name="_RecipeCard" model="recipe" />
                }
            </div>
        }
        else
        {
            <div class="empty-state mt-4">
                No recipes found.
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="~/js/search.js" asp-append-version="true"></script>
}
