@page "{id:int}"
@model RecipesFinalProjectController.Pages.EditRecipeModel
@{
    ViewData["Title"] = "Edit Recipe";
}

@section Styles {
    <link rel="stylesheet" href="~/css/create-recipe.css" asp-append-version="true" />
}

<div class="create-recipe-page">
    <div class="create-recipe-shell">
        <div class="create-recipe-header">
            <h1 class="page-title">Edit Recipe</h1>
            <p class="create-recipe-subtitle">
                Update your recipe information. After editing, the recipe will be pending admin approval again.
            </p>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.Message))
        {
            <div class="alert alert-success" data-auto-hide="true">
                @Model.Message
            </div>
        }

        @if (!ViewContext.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="alert alert-danger"></div>
        }

        <form method="post" enctype="multipart/form-data" class="create-recipe-card">
            <div class="create-recipe-card-body">
                <input type="hidden" asp-for="Recipe.Id" />

                <div class="row g-4">
                    <div class="col-lg-7">
                        <div class="form-section">
                            <h4 class="section-title">Basic Information</h4>

                            <div class="mb-3">
                                <label class="form-label create-label">Title</label>
                                <input asp-for="Recipe.Title" class="form-control create-input" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label create-label">Preparation Method</label>
                                <textarea asp-for="Recipe.PreparationMethod" class="form-control create-input" rows="7"></textarea>
                            </div>

                            <div class="mb-3">
                                <label class="form-label create-label">Preparation Time (minutes)</label>
                                <input asp-for="Recipe.PreparationTime" type="number" step="1" class="form-control create-input" />
                            </div>
                        </div>

                        <div class="form-section">
                            <h4 class="section-title">Category & Difficulty</h4>

                            <div class="mb-3">
                                <label class="form-label create-label">Category</label>
                                <select asp-for="CategoryId" class="form-select create-input">
                                    @foreach (var c in Model.Categories)
                                    {
                                        <option value="@c.Id">@c.Name</option>
                                    }
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label create-label">Difficulty</label>
                                <select asp-for="DifficultyId" class="form-select create-input">
                                    @foreach (var d in Model.Difficulties)
                                    {
                                        <option value="@d.Id">@d.Name</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-5">
                        <div class="form-section">
                            <h4 class="section-title">Recipe Image</h4>

                            <div class="mb-3">
                                <label class="form-label create-label">Current Image</label>
                                <div class="image-preview-box" id="imagePreviewContainer" style="display:flex;">
                                    @if (!string.IsNullOrWhiteSpace(Model.Recipe.ImageUrl))
                                    {
                                        <img src="@Model.Recipe.ImageUrl" alt="@Model.Recipe.Title" id="imagePreview" />
                                    }
                                    else
                                    {
                                        <img src="" alt="Preview" id="imagePreview" style="display:none;" />
                                        <span class="text-muted">No image uploaded yet</span>
                                    }
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label create-label">Replace Image</label>
                                <input asp-for="ImageFile"
                                       type="file"
                                       accept="image/*"
                                       class="form-control create-input"
                                       id="imageInput" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-section ingredients-section">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4 class="section-title mb-0">Ingredients</h4>
                        <button type="button" class="btn btn-outline-secondary" onclick="addIngredientRow()">
                            Add Ingredient
                        </button>
                    </div>

                    <div class="ingredients-table-wrap">
                        <table class="table ingredients-table" id="ingredientsTable">
                            <thead>
                                <tr>
                                    <th>Ingredient</th>
                                    <th>New Ingredient</th>
                                    <th>Quantity</th>
                                    <th>Measure</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.ExistingIngredients.Any())
                                {
                                    @foreach (var line in Model.ExistingIngredients)
                                    {
                                        <tr>
                                            <td>
                                                <select name="IngredientIds" class="form-select create-input">
                                                    <option value="">Select ingredient</option>
                                                    @foreach (var i in Model.Ingredients)
                                                    {
                                                        if (i.Id == line.Ingredient.Id)
                                                        {
                                                            <option value="@i.Id" selected>@i.Name</option>
                                                        }
                                                        else
                                                        {
                                                            <option value="@i.Id">@i.Name</option>
                                                        }
                                                    }
                                                </select>
                                            </td>
                                            <td>
                                                <input name="NewIngredientNames"
                                                       class="form-control create-input"
                                                       placeholder="Or type new ingredient" />
                                            </td>
                                            <td>
                                                <input name="Quantities"
                                                       type="number"
                                                       step="0.01"
                                                       min="0.01"
                                                       class="form-control create-input"
                                                       value="@line.Quantity" />
                                            </td>
                                            <td>
                                                <input name="Measures"
                                                       class="form-control create-input"
                                                       value="@line.Measure" />
                                            </td>
                                            <td>
                                                <button type="button" class="btn btn-outline-danger" onclick="removeRow(this)">
                                                    X
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td>
                                            <select name="IngredientIds" class="form-select create-input">
                                                <option value="">Select ingredient</option>
                                                @foreach (var i in Model.Ingredients)
                                                {
                                                    <option value="@i.Id">@i.Name</option>
                                                }
                                            </select>
                                        </td>
                                        <td>
                                            <input name="NewIngredientNames"
                                                   class="form-control create-input"
                                                   placeholder="Or type new ingredient" />
                                        </td>
                                        <td>
                                            <input name="Quantities"
                                                   type="number"
                                                   step="0.01"
                                                   min="0.01"
                                                   class="form-control create-input" />
                                        </td>
                                        <td>
                                            <input name="Measures"
                                                   class="form-control create-input"
                                                   placeholder="g / ml / pcs" />
                                        </td>
                                        <td>
                                            <button type="button" class="btn btn-outline-danger" onclick="removeRow(this)">
                                                X
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="form-text">
                        You can update ingredient rows, remove them, or add new ones.
                    </div>
                </div>

                <div class="create-actions">
                    <button type="submit" class="btn btn-main create-submit-btn">Save Changes</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/create-recipe.js" asp-append-version="true"></script>
}