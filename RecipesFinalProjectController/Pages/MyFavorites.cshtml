@page
@model RecipesFinalProjectController.Pages.MyFavoritesModel
@{
    ViewData["Title"] = "My Favorites";
}

@section Styles {
    <link rel="stylesheet" href="~/css/favorites.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/search.css" asp-append-version="true" />
}

<div class="favorites-page">
    <div class="favorites-shell">
        <div class="favorites-header">
            <h1 class="page-title">My Favorite Recipes</h1>
            <p class="favorites-subtitle">All the recipes you saved in one place.</p>
        </div>

        @if (Model.Favorites.Any())
        {
            <div class="results-count mb-3">
                @Model.Favorites.Count favorites
            </div>

            <div class="recipe-grid">
                @foreach (var recipe in Model.Favorites)
                {
                    <partial name="_RecipeCard" model="recipe" />
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                You have no favorite recipes yet.
            </div>
        }
    </div>
</div>