@page "{id:int}"
@model RecipesFinalProjectController.Pages.RecipeDetailsModel
@{
    ViewData["Title"] = "Recipe Details";
}

@section Styles {
    <link rel="stylesheet" href="~/css/recipe-details.css" asp-append-version="true" />
}

<div class="recipe-details-page">
    <h2 class="page-title">@Model.Recipe.Title</h2>

    @if (!string.IsNullOrWhiteSpace(Model.Recipe.ImageUrl))
    {
        <div class="recipe-hero mb-4">
            <img src="@Model.Recipe.ImageUrl" alt="@Model.Recipe.Title" class="recipe-main-image" />
        </div>
    }

    <div class="recipe-detail-box p-4 mb-3">
        <p><strong>Category:</strong> @Model.Recipe.Category?.Name</p>
        <p><strong>Difficulty:</strong> @Model.Recipe.Difficulty?.Name</p>
        <p><strong>Time:</strong> @Model.Recipe.PreparationTime min</p>
        <p><strong>Average Rating:</strong> @Model.AverageRating.ToString("0.0") ⭐</p>

        @if (User.Identity.IsAuthenticated)
        {
            <form method="post" asp-page-handler="ToggleFavorite" class="mt-3">
                <input type="hidden" name="recipeId" value="@Model.Recipe.Id" />

                @if (Model.IsFavorite)
                {
                    <button type="submit" class="btn btn-danger">❤ Remove Favorite</button>
                }
                else
                {
                    <button type="submit" class="btn btn-outline-danger">♡ Add Favorite</button>
                }
            </form>
        }
    </div>

    <div class="recipe-detail-box p-4 mb-3">
        <h4 class="section-title">Preparation</h4>
        <p>@Model.Recipe.PreparationMethod</p>
    </div>

    <div class="recipe-detail-box p-4 mb-3">
        <h4 class="section-title">Ingredients</h4>
        @if (Model.Ingredients.Any())
        {
            <ul>
                @foreach (var ingredient in Model.Ingredients)
                {
                    <li>@ingredient.Quantity @ingredient.Measure @ingredient.Ingredient?.Name</li>
                }
            </ul>
        }
        else
        {
            <p>No ingredients listed.</p>
        }
    </div>

    @if (User.Identity.IsAuthenticated)
    {
        <div class="recipe-detail-box p-4 mb-3">
            <h4 class="section-title">Rate this recipe</h4>

            <form method="post" asp-page-handler="Rate">
                <input type="hidden" name="recipeId" value="@Model.Recipe.Id" />

                <div class="mb-3">
                    <select asp-for="Score" class="form-select">
                        <option value="1">1 Star</option>
                        <option value="2">2 Stars</option>
                        <option value="3">3 Stars</option>
                        <option value="4">4 Stars</option>
                        <option value="5">5 Stars</option>
                    </select>
                </div>

                <button type="submit" class="btn btn-main">Submit Rating</button>
            </form>
        </div>

        <div class="recipe-detail-box p-4 mb-3">
            <h4 class="section-title">Add Comment</h4>

            <form method="post" asp-page-handler="Comment">
                <input type="hidden" name="recipeId" value="@Model.Recipe.Id" />

                <div class="mb-3">
                    <textarea asp-for="CommentText" class="form-control" rows="3" placeholder="Write your comment"></textarea>
                </div>

                <button type="submit" class="btn btn-main">Post Comment</button>
            </form>
        </div>
    }

    <div class="recipe-detail-box p-4">
        <h4 class="section-title">Comments</h4>

        @if (Model.Comments.Any())
        {
            @foreach (var comment in Model.Comments)
            {
                <div class="comment-card mb-2">
                    <strong>@comment.User?.Username</strong>
                    <p class="mb-0">@comment.CommentText</p>
                </div>
            }
        }
        else
        {
            <p>No comments yet.</p>
        }
    </div>
</div>
