@page "{id:int}"
@model RecipesFinalProjectController.Pages.RecipeDetailsModel
@{
    ViewData["Title"] = "Recipe Details";
}

@section Styles {
    <link rel="stylesheet" href="~/css/recipe-details.css" asp-append-version="true" />
}

<div class="recipe-details-page">
    <div class="recipe-details-shell">
        <div class="recipe-header">
            <h1 class="page-title">@Model.Recipe.Title</h1>

            <div class="recipe-header-meta">
                @if (Model.Recipe.Category != null && !string.IsNullOrWhiteSpace(Model.Recipe.Category.Name))
                {
                    <span class="detail-chip">@Model.Recipe.Category.Name</span>
                }

                @if (Model.Recipe.Difficulty != null && !string.IsNullOrWhiteSpace(Model.Recipe.Difficulty.Name))
                {
                    <span class="detail-chip">@Model.Recipe.Difficulty.Name</span>
                }

                <span class="detail-chip">@Model.Recipe.PreparationTime min</span>
                <span class="detail-chip">⭐ @Model.AverageRating.ToString("0.0")</span>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.Recipe.ImageUrl))
        {
            <div class="recipe-hero mb-4">
                <img src="@Model.Recipe.ImageUrl" alt="@Model.Recipe.Title" class="recipe-main-image" />
            </div>
        }

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="recipe-detail-box p-4 mb-4">
                    <h4 class="section-title">Preparation</h4>
                    <p class="recipe-description">@Model.Recipe.PreparationMethod</p>
                </div>

                <div class="recipe-detail-box p-4 mb-4">
                    <h4 class="section-title">Comments</h4>

                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <form method="post" asp-page-handler="Comment" class="mb-4">
                            <input type="hidden" name="recipeId" value="@Model.Recipe.Id" />

                            <div class="mb-3">
                                <textarea asp-for="CommentText" class="form-control recipe-input" rows="3" placeholder="Write your comment"></textarea>
                            </div>

                            <button type="submit" class="btn btn-main">Post Comment</button>
                        </form>
                    }

                    @if (Model.Comments.Any())
                    {
                        @foreach (var comment in Model.Comments)
                        {
                            <div class="comment-card mb-3">
                                <strong>@comment.User?.Username</strong>
                                <p class="mb-0 mt-1">@comment.CommentText</p>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted mb-0">No comments yet.</p>
                    }
                </div>
            </div>

            <div class="col-lg-4">
                <div class="recipe-detail-box p-4 mb-4">
                    <h4 class="section-title">Recipe Info</h4>

                    <p><strong>Category:</strong> @Model.Recipe.Category?.Name</p>
                    <p><strong>Difficulty:</strong> @Model.Recipe.Difficulty?.Name</p>
                    <p><strong>Time:</strong> @Model.Recipe.PreparationTime min</p>
                    <p><strong>Average Rating:</strong> @Model.AverageRating.ToString("0.0") ⭐</p>

                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <form method="post" asp-page-handler="ToggleFavorite" class="mt-3">
                            <input type="hidden" name="recipeId" value="@Model.Recipe.Id" />

                            @if (Model.IsFavorite)
                            {
                                <button type="submit" class="btn btn-danger w-100">❤ Remove Favorite</button>
                            }
                            else
                            {
                                <button type="submit" class="btn btn-outline-danger w-100">♡ Add Favorite</button>
                            }
                        </form>
                    }
                </div>

                <div class="recipe-detail-box p-4 mb-4">
                    <h4 class="section-title">Ingredients</h4>

                    @if (Model.Ingredients.Any())
                    {
                        <ul class="ingredient-list">
                            @foreach (var ingredient in Model.Ingredients)
                            {
                                <li>@ingredient.Quantity @ingredient.Measure @ingredient.Ingredient?.Name</li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted mb-0">No ingredients listed.</p>
                    }
                </div>

                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <div class="recipe-detail-box p-4">
                        <h4 class="section-title">Rate this recipe</h4>

                        <form method="post" asp-page-handler="Rate">
                            <input type="hidden" name="recipeId" value="@Model.Recipe.Id" />

                            <div class="mb-3">
                                <select asp-for="Score" class="form-select recipe-input">
                                    <option value="1">1 Star</option>
                                    <option value="2">2 Stars</option>
                                    <option value="3">3 Stars</option>
                                    <option value="4">4 Stars</option>
                                    <option value="5">5 Stars</option>
                                </select>
                            </div>

                            <button type="submit" class="btn btn-main w-100">Submit Rating</button>
                        </form>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
